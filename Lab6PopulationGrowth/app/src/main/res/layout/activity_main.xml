<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FFF7FF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Population Growth"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#6B4CB3"
        android:padding="14dp" />

    <EditText
        android:id="@+id/startInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter the starting population"
        android:inputType="number" />

    <EditText
        android:id="@+id/daysInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter the number of days"
        android:inputType="number" />

    <EditText
        android:id="@+id/rateInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter the growth rate (as a %)"
        android:inputType="numberDecimal" />

    <Button
        android:id="@+id/calculateButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Calculate Population" />

    <TextView
        android:id="@+id/resultsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Results here."
        android:textSize="14sp"
        android:paddingTop="16dp" />

</LinearLayout>